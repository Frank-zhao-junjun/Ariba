        "requisition_management": {
          "name": "采购申请管理",
          "features": [
            "自助请购",
            "多层级审批流",
            "预算关联",
            "成本中心分配",
            "审批规则引擎",
            "移动端审批",
            "邮件通知",
            "草稿保存",
