            "经理审批",
            "采购部门确认",
            "订单创建"
          ]
        },
        "purchase_order": {
          "name": "采购订单管理",
          "features": [
            "标准PO创建",
            "订单审批",
            "订单变更",
            "订单确认",
            "订单分发",
            "订单状态跟踪",
