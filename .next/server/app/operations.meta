{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/operations/layout,_N_T_/(app)/operations/page,_N_T_/operations"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/operations/__PAGE__",
    "/!KGFwcCk/operations",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}