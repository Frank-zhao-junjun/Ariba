    {
      "name": "lint",
      "command": "pnpm lint .",
      "required": true
    },
    {
      "name": "typecheck",
      "command": "pnpm ts-check",
      "required": true
    },
    {
      "name": "build",
      "command": "pnpm exec next build",
      "required": true
    },
    {
      "name": "deploy-smoke",
      "command": "pnpm exec next start --port 5000",
      "required": false
    }
  ],
  "baseline": {
    "install": "pass",
    "lint": "pass",
    "typecheck": "pass",
    "build": "pass",
    "tests": "pass"
