{
  "project": {
    "name": "Ariba 项目实施助手",
    "method": "Ralph",
    "initializedAt": "2026-04-16",
    "repoRoot": "."
  },
  "sourceDocs": [
    "AGENTS.md",
    "README.md",
    "SPEC.md",
    "src/lib/data.ts"
  ],
  "selectionRule": "Select the highest priority story with passes=false and all dependsOn stories marked passes=true. Execute exactly one story per loop.",
  "qualityGates": [
    {
      "name": "story-test",
      "command": "pnpm exec tsx --test <story-test-file>",
      "required": true
    },
    {
      "name": "lint",
      "command": "pnpm lint .",
      "required": true
    },
    {
      "name": "typecheck",
      "command": "pnpm ts-check",
      "required": true
    },
    {
      "name": "build",
      "command": "pnpm exec next build",
      "required": true
    },
    {
      "name": "deploy-smoke",
      "command": "pnpm exec next start --port 5000",
      "required": false
    }
  ],
  "baseline": {
    "install": "pass",
    "lint": "pass",
    "typecheck": "pass",
    "build": "pass",
    "tests": "pass"
  },
  "stories": [
    {
      "id": "US-001",
      "priority": 1,
      "title": "AI 助手消息发送稳定化",
      "userStory": "作为实施顾问，我希望在 AI 助手页面发送问题时，消息能稳定追加并展示回复，不因为不纯的消息 ID 生成逻辑阻塞质量门禁。",
      "dependsOn": [],
      "paths": [
        "src/app/(app)/assistant/page.tsx",
        "src/lib/assistant.ts",
        "src/lib/assistant.test.ts"
      ],
      "acceptance": [
        "发送问题后立即追加用户消息。",
        "模拟回复追加为独立 assistant 消息。",
        "消息创建逻辑从页面组件抽离，避免在组件渲染域内直接调用 Date.now。",
        "当前故事包含可执行自动化测试。"
      ],
      "testPlan": [
        "pnpm exec tsx --test src/lib/assistant.test.ts",
        "pnpm lint .",
        "pnpm ts-check",
        "pnpm exec next build"
      ],
      "deployPlan": [
        "pnpm exec next build",
        "pnpm exec next start --port 5000"
      ],
      "passes": true
    },
    {
      "id": "US-002",
      "priority": 2,
      "title": "首页仪表板刷新与时间状态稳定化",
      "userStory": "作为项目经理，我希望首页刷新操作和更新时间展示稳定、可预测，避免 hydration 和交互异常。",
      "dependsOn": [],
      "paths": [
        "src/app/(app)/page.tsx",
        "src/lib/dashboard.ts",
        "src/lib/dashboard.test.ts"
      ],
      "acceptance": [
        "刷新动作只更新需要变化的时间状态。",
        "更新时间展示不引入 hydration 风险。",
        "首页关键 CTA 仍可导航到项目和任务。"
      ],
      "testPlan": [
        "pnpm lint src/app/(app)/page.tsx",
        "pnpm ts-check",
        "pnpm exec next build"
      ],
      "deployPlan": [
        "pnpm exec next start --port 5000"
      ],
      "passes": true
    },
