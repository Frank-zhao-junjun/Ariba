# Ariba助手 - 环境变量配置示例

# 服务配置
PORT=3000
NODE_ENV=development
LOG_LEVEL=INFO

# Ariba API 配置
ARIBAS_API_URL=https://purchase.coze.cn

# Coze Webhook 配置
COZE_WEBHOOK_SECRET=your_webhook_secret_here

# 飞书配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_ADMIN_OPENID=ou_xxxxxxxxxxxxxxxx
